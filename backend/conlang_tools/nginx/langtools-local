server {
    listen 80;
    server_name 192.168.1.116 192.168.1.41;  # Replace with your server's IP or hostname

    root /app;
    index index.html;

    location / {
        #try_files $uri $uri/ /index.html;
        try_files $uri $uri/ =404;  # Try static files first; if none is found, return 404
    }
    # Catch all other routes and serve index.html for Angular routing
    error_page 404 /index.html;
    location = /index.html {
        allow all;
    }
    # Serve static files in the build directory directly without redirect
    location ~* \.(?:ico|css|js|map|jpe?g|png|gif|otf|eot|svg|ttf|woff|woff2)$ {
        try_files $uri =404;
        access_log off;           # Optional: Turns off the access logs for static files
        add_header Cache-Control "public, must-revalidate, proxy-revalidate";
    }

    location /services/ {
        proxy_pass http://localhost:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /ai/ {
        proxy_pass http://localhost:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
